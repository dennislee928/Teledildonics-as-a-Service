CONTROL_API_ADDR=:8080
CONTROL_API_PUBLIC_URL=http://localhost:8080
STATIC_ROOT=.
OIDC_ISSUER=https://example-issuer.invalid
OIDC_AUDIENCE=taas-console
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_REALTIME_APP_ID=
CLOUDFLARE_TURN_SERVICE_ID=
STORE_REPOSITORY_BACKEND=memory
STORE_RUNTIME_BACKEND=memory
REDIS_URL=redis://localhost:6379
POSTGRES_DSN=postgres://taas:taas@localhost:5432/taas?sslmode=disable

# Local seeded workspace API key for /v1/* requests:
# X-Workspace-Api-Key: taas_demo_workspace_key

# Demo app (Next.js): Control API base URL for fetch (e.g. Docker host or CONTROL_API_PUBLIC_URL)
# NEXT_PUBLIC_TAAS_API_URL=http://localhost:8080
