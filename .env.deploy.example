# Copy this file to `.env.deploy` and adjust values for your own accounts.
# Secrets like KOYEB_TOKEN and HF_TOKEN should stay out of git.

# Shared application defaults
APP_PUBLIC_PORT=8080
APP_STATIC_ROOT=/srv/taas
STORE_REPOSITORY_BACKEND=memory
STORE_RUNTIME_BACKEND=memory
# For free demo hosts, the in-memory defaults are the safest path.
# If you attach managed data services later, you can switch to:
# POSTGRES_DSN=postgres://...
# REDIS_URL=redis://...

# Koyeb deployment
KOYEB_APP_NAME=taas-demo
KOYEB_SERVICE_NAME=taas-demo
KOYEB_GIT_BRANCH=main
# KOYEB_GIT_REPO=github.com/your-user/Teledildonics-as-a-Service
KOYEB_APP_PORT=8080
KOYEB_STATIC_ROOT=/srv/taas
KOYEB_WAIT_TIMEOUT=10m
# KOYEB_ORGANIZATION=
# KOYEB_TOKEN=

# Hugging Face Space deployment
HF_SPACE_ID=your-user/taas-demo
HF_SPACE_BRANCH=main
HF_SPACE_TITLE=TaaS Demo
HF_SPACE_EMOJI=🛰️
HF_SPACE_COLOR_FROM=red
HF_SPACE_COLOR_TO=orange
HF_SPACE_PRIVATE=false
# HF_USERNAME=your-user
# HF_TOKEN=
